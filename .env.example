# ============================================================
# All Money Back Me Home — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# --- API Keys ---
FUGLE_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# --- OKX API (Demo Trading) ---
# Create demo API key at: OKX > Trade > Demo Trading > Profile > Create API Key
# These env vars are for reference; Freqtrade reads from config_secrets_demo.json
OKX_API_KEY=your_api_key_here
OKX_SECRET=your_secret_here
OKX_PASSPHRASE=your_passphrase_here

# --- Telegram Bot ---
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# --- Web ---
API_BASE_URL=http://api:8000

# --- Trading ---
INITIAL_CAPITAL=300.0

# --- Institutional Reports ---
FINNHUB_API_KEY=               # Free: https://finnhub.io/register (60 calls/min)
CRYPTOPANIC_API_KEY=           # Free: https://cryptopanic.com/developers/api/

# --- AI (for report digest) ---
ANTHROPIC_API_KEY=             # Claude API for digest generation
ANTHROPIC_BASE_URL=            # Optional: custom API endpoint

# --- Freqtrade API ---
FT_USER=freqtrade
FT_PASS=your_ft_password

# --- Logging ---
LOG_LEVEL=INFO
