# ============================================================
# All Money Back Me Home — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# --- API Keys ---
FUGLE_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# --- OKX API (Demo Trading) ---
# Create demo API key at: OKX > Trade > Demo Trading > Profile > Create API Key
# These env vars are for reference; Freqtrade reads from config_secrets_demo.json
OKX_API_KEY=your_api_key_here
OKX_SECRET=your_secret_here
OKX_PASSPHRASE=your_passphrase_here

# --- Telegram Bot ---
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# --- Web ---
API_BASE_URL=http://api:8000

# --- Trading ---
INITIAL_CAPITAL=300.0

# --- Institutional Reports ---
FINNHUB_API_KEY=               # Free: https://finnhub.io/register (60 calls/min)
CRYPTOPANIC_API_KEY=           # Free: https://cryptopanic.com/developers/api/

# --- AI (for report digest) ---
ANTHROPIC_API_KEY=             # Claude API for digest generation
ANTHROPIC_BASE_URL=            # Optional: custom API endpoint

# --- Institutional MCP Data (paid, optional — engine works without these) ---
LSEG_API_KEY=                  # LSEG analytics: yield curves, swap curves, macro rates
LSEG_API_SECRET=               # LSEG API secret (paired with API key)
MT_NEWSWIRES_API_KEY=          # MT Newswires: real-time macro economic news
MOODYS_API_KEY=                # Moody's: credit ratings, migration signals
FACTSET_API_KEY=               # FactSet: consensus estimates, earnings revisions

# --- Freqtrade API ---
FT_USER=freqtrade
FT_PASS=your_ft_password

# --- Logging ---
LOG_LEVEL=INFO

# ============================================================
# SUPERTREND Strategy switchboard (R47–R58).
# All defaults are SAFE — leave commented to inherit existing behavior.
# Uncomment + set to opt into specific features.
# Reference: strategies/supertrend.py docstrings + each module's tests.
# ============================================================
# Live trading (REAL MONEY ON OKX) — DEFAULT IS DRY-RUN PAPER TRADING.
# Only set to 1 after a validated dry-run shadow + .env credentials confirmed.
# SUPERTREND_LIVE=0

# Market regime gate (R48). Default ON. Set to 0 to bypass (NOT recommended).
# SUPERTREND_REGIME_FILTER=1

# Kelly mode (R49): three_stage (default) | continuous | binary
# SUPERTREND_KELLY_MODE=three_stage

# Exit policy (R50): weighted (default) | legacy
# SUPERTREND_EXIT_MODE=weighted

# --- ALPHA FILTERS (R57+R58, all default OFF) ----------------
# Enable individually after a paper-trading observation epoch.

# Funding rate contra-signal — blocks entries against extreme FR (R57)
# SUPERTREND_FR_ALPHA=1

# Orderbook microstructure confirm — adds REST latency, gates entries (R57)
# SUPERTREND_ORDERBOOK_CONFIRM=1

# Correlation cluster + dominance rotation sizing (R58)
# SUPERTREND_CORRELATION_FILTER=1

# Journal location (R46+) — host path for dashboard/cron sidecar to read
# SUPERTREND_JOURNAL_DIR=/freqtrade/trading_log/journal

# --- DASHBOARD POLLUTION FILTER (R140 / 774cafd) ----------------------------
# 已知污染日列表 (ISO YYYY-MM-DD, 逗號分隔). /operations 跟 /snapshot
# 預設用這個列表排除特定日期, 避免 force_entry tests / backtest pollution
# 拉壞 dashboard 上的 win-rate / Sharpe / drawdown 數字。
# 已知污染日：
#   2026-04-25  force_entry test trades x2
#   2026-04-26  R84/R85 backtest runs (R115 之前的) 寫入 prod journal 共 201 筆
# SUPERTREND_OPS_EXCLUDE_DATES=2026-04-25,2026-04-26

# --- SMART MONEY MIGRATION (R131) ----------------------------
# 設這個讓 smart-money / smart-money-shadow container 能跑 supabase
# migrations (供 smart_money 模組使用)。不設則所有 supabase/migrations/
# *.sql 都會 skip (deploy 印 warning 但不 fail). Phase 0 stub 還沒用 DB,
# 先不設也 OK; 之後 smart_money tables 上線 (Phase 2+) 必須設。
# SM_DATABASE_URL=postgresql://postgres:<password>@<supabase-host>:5432/postgres
